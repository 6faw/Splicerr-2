{
    "$schema": "../gen/schemas/desktop-schema.json",
    "identifier": "default",
    "description": "Capability for the main window",
    "windows": ["main"],
    "permissions": [
        "core:default",
        "opener:default",
        {
            "identifier": "http:default",
            "allow": [
                {
                    "url": "https://spliceproduction.s3.*.amazonaws.com/**"
                },
                {
                    "url": "https://*.splice.com/**"
                },
                {
                    "url": "https://*.amazonaws.com/spliceblob.splice.com/**"
                },
                {
                    "url": "https://www.myinstants.com/**"
                },
                {
                    "url": "https://tuna-api.voicemod.net/**"
                },
                {
                    "url": "https://us-tuna-sounds-files.voicemod.net/**"
                },
                {
                    "url": "https://us-tuna-sounds-images.voicemod.net/**"
                },
                {
                    "url": "https://www.epidemicsound.com/**"
                },
                {
                    "url": "https://audiocdn.epidemicsound.com/**"
                },
                {
                    "url": "https://cdn.epidemicsound.com/**"
                },
                {
                    "url": "https://api.prosoundeffects.com/**"
                },
                {
                    "url": "https://www.prosoundeffects.com/**"
                },
                {
                    "url": "https://prosoundeffects.blob.core.windows.net/**"
                },
                {
                    "url": "https://www.soundsnap.com/**"
                },
                {
                    "url": "https://ts231.search-soundsnap.com/**"
                },
                {
                    "url": "https://soundsnap-prod.nyc3.digitaloceanspaces.com/**"
                },
                {
                    "url": "https://sounddogs.com/**"
                },
                {
                    "url": "https://*.loopmasters.com/**"
                },
                {
                    "url": "https://cloud.loopmasters.com/**"
                },
                {
                    "url": "https://demos.loopmasters.com/**"
                },
                {
                    "url": "https://*.loopcloud.net/**"
                },
                {
                    "url": "https://*.cloudfront.net/**"
                },
                {
                    "url": "https://d2cx9kaw24fnh5.cloudfront.net/**"
                },
                {
                    "url": "https://audiio.com/**"
                },
                {
                    "url": "https://*.audiio.com/**"
                },
                {
                    "url": "https://*.envato.com/**"
                },
                {
                    "url": "https://*.audiojungle.net/**"
                }
            ]
        },
        "core:webview:allow-set-webview-zoom",
        "drag:default",
        "fs:default",
        "fs:allow-stat",
        "fs:allow-mkdir",
        "fs:allow-create",
        "fs:allow-write-file",
        "fs:allow-write-text-file",
        {
            "identifier": "fs:scope",
            "allow": [
                {
                    "path": "**"
                }
            ]
        },
        "dialog:default"
    ]
}
